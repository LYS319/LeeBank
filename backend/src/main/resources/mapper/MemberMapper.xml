<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bank.mapper.MemberMapper">

    <resultMap id="memberResultMap" type="com.bank.dto.MemberDto">
        <id     property="memberId"  column="member_id"/>
        <result property="name"      column="name"/>
        <result property="password"  column="password"/>
        <result property="phone"     column="phone"/>
    </resultMap>

    <!-- 회원 ID로 조회 -->
    <select id="selectByMemberId" resultMap="memberResultMap">
        SELECT member_id, name, password, phone
        FROM MEMBER
        WHERE member_id = #{memberId}
    </select>

    <!-- 아이디 중복 체크 — 0이면 사용 가능 -->
    <select id="countByMemberId" resultType="int">
        SELECT COUNT(*)
        FROM MEMBER
        WHERE member_id = #{memberId}
    </select>

    <!-- 회원가입 — 신규 회원 INSERT -->
    <!-- name은 평문 그대로, password는 SHA-256 해시, phone은 AES-256 암호화된 값이 Service에서 넘어옴 -->
    <insert id="insert" parameterType="com.bank.dto.MemberDto">
        INSERT INTO MEMBER (member_id, name, password, phone, created_at)
        VALUES (#{memberId}, #{name}, #{password}, #{phone}, SYSDATE)
    </insert>

</mapper>